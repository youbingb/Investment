# 复制到 .env 后填入真实值；.env 已在 .gitignore 中
# 真实 .env 永远不要 commit

# === OKX 公开行情 ===
# 公开 K 线接口不需要 API key；如果遇到地区/限频问题可切到香港或新加坡入口
OKX_BASE_URL=https://www.okx.com
OKX_REQUEST_TIMEOUT=10

# === 飞书自建应用 ===
# 1. 飞书开放平台 → 创建自建应用 → 「凭证与基础信息」拿 app_id / app_secret
# 2. 「权限管理」开通 im:message + im:message.group_at_msg
# 3. 「应用功能 → 机器人」启用并发布上线
# 4. 把机器人加到目标群，调 chat.list 接口或事件订阅拿 chat_id
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=

# 调试用：是否真的调用飞书 API（false 时只打印到 stdout）
FEISHU_DRY_RUN=true

# === 日志 ===
LOG_LEVEL=INFO
