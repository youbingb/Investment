# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.uv/
.python-version

# 测试 / 构建
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/

# 秘钥与本地配置（永远不能入库）
.env
.env.local
.env.*.local

# 数据缓存（按需重新拉，不入库）；保留 .gitkeep 让目录入库
data/cache/*
!data/cache/.gitkeep
data/reports/*
!data/reports/.gitkeep
*.parquet

# 临时缓存 / 工具中间产物
.cache/
.playwright-mcp/

# 编辑器
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# 日志
logs/
*.log
